{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./.next/types",
    "composite": true,
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "src/**/*", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"],
  "references": [{ "path": "../../packages/types" }, { "path": "../../services/mpp-sim" }]
}
