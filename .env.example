# Agent LLM backend: "anthropic" (default) or "openai_compat"
LLM_BACKEND=anthropic

# --- Anthropic ---
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
ANTHROPIC_MODEL=

# --- OpenAI-compatible local LLM (LM Studio / Ollama / vLLM / llama.cpp / LocalAI) ---
# LM Studio default; override for Ollama (http://localhost:11434/v1) or others
OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
# Required when LLM_BACKEND=openai_compat. The model id LM Studio shows for the
# currently-loaded model (e.g. qwen2.5-coder-32b-instruct, llama-3.3-70b-instruct).
OPENAI_COMPAT_MODEL=
# Optional. LM Studio + Ollama accept any value; set this when the endpoint enforces auth.
OPENAI_COMPAT_API_KEY=

# Base Sepolia RPC
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_SEPOLIA_CHAIN_ID=84532

# Deployed contract addresses (filled after forge script Deploy)
ESCROW_ADDRESS=
CREDIT_LINE_ADDRESS=
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Smart wallet / paymaster (Coinbase Smart Wallet or Privy)
SMART_WALLET_PROVIDER=coinbase
PAYMASTER_URL=

# MPP simulator
# Hex-encoded Ed25519 private key (32 bytes). Generate via scripts/gen-mpp-key.ts
MPP_ISSUER_PRIVATE_KEY=
MPP_ISSUER_ID=mpp-sim://issuer/visa-poc

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Mock providers
HYPERSCALER_BASE_URL=http://localhost:3000/api/providers/hyperscaler
DCOMP_BASE_URL=http://localhost:3000/api/providers/dcomp
