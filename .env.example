# --- Agent LLM backend (omit to run the scripted fallback plan) ---
# Set to "anthropic" or "openai_compat", or leave unset for the scripted demo.
# LLM_BACKEND=anthropic

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6   # optional override

# OpenAI-compatible local LLM (LM Studio / Ollama / vLLM / llama.cpp / LocalAI)
# OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1   # LM Studio default
# OPENAI_COMPAT_MODEL=qwen2.5-coder-32b-instruct    # whatever LM Studio shows
# OPENAI_COMPAT_API_KEY=                            # optional

# --- Mock providers (apps/web). Leave default to use `pnpm dev`. ---
DCOMP_BASE_URL=http://localhost:3000/api/providers/dcomp
HYPERSCALER_BASE_URL=http://localhost:3000/api/providers/hyperscaler

# --- Task overrides (optional) ---
# TASK_DESCRIPTION=render 60s of 4K video, deadline 2h
# TASK_BUDGET_USD=200

# --- Tier 2: Supabase ledger ---
# When set, the agent + reconciler persist to Postgres instead of buffering
# in memory. Run `supabase start` locally first; then `supabase db reset`
# to apply supabase/migrations/0001_init.sql.
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Tier 3: Base Sepolia onchain ---
# When ESCROW_ADDRESS + CREDIT_LINE_ADDRESS + BASE_SEPOLIA_RPC + USDC_ADDRESS
# are set, scripts/agent.ts swaps the in-memory CreditPort + EscrowPort for
# OnchainCreditPort + OnchainEscrowPort that transact against the deployed
# contracts. Two ways to source a signer; pick exactly one.
# BASE_SEPOLIA_RPC=https://sepolia.base.org
# BASE_SEPOLIA_CHAIN_ID=84532
# USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# ESCROW_ADDRESS=
# CREDIT_LINE_ADDRESS=

# Signer option A: raw private key (simplest, but you hold the key)
# AGENT_PRIVATE_KEY=

# Signer option B: Privy server wallet (recommended; Privy custodies the key)
# 1. Sign up at https://dashboard.privy.io and create an app.
# 2. Paste the App ID + App Secret here. Optional authorization key only
#    needed if your Privy app requires signed wallet API calls.
# 3. Run `pnpm script:provision-wallet` to mint a wallet — it auto-writes
#    PRIVY_WALLET_ID + PRIVY_WALLET_ADDRESS back into this file.
# 4. Fund the printed address with Base Sepolia ETH + USDC, then run
#    `pnpm script:agent`.
# PRIVY_APP_ID=
# PRIVY_APP_SECRET=
# PRIVY_WALLET_AUTHORIZATION_PRIVATE_KEY=
# PRIVY_WALLET_ID=
# PRIVY_WALLET_ADDRESS=

# --- Onchain deploy script (scripts/deploy.sh) ---
# DEPLOYER_PRIVATE_KEY=                           # required by deploy.sh
# CREDIT_LINE_SEED_USDC6=10000000                 # optional; 10 USDC pool seed

# --- MPP simulator (optional persistence) ---
# In the current build the simulator generates an ephemeral Ed25519 keypair
# per process. Persist these to share an issuer across runs.
# MPP_ISSUER_PRIVATE_KEY=
# MPP_ISSUER_ID=mpp-sim://issuer/visa-poc

# --- Misc ---
# LOG_LEVEL=info   # debug | info | warn | error
